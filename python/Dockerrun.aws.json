{
    "AWSEBDockerrunVersion": "2",
    "containerDefinitions": [
        {
            "name": "aiadvisor_prod",
            "image": "250623887600.dkr.ecr.us-east-2.amazonaws.com/aiadvisor:latest",
            "portMappings": [
                {
                    "containerPort": 80
                }
            ],
            "environment": [
                {
                    "name": "OPENAI_API_KEY",
                    "value": ""
                },
                {
                    "name": "PINECONE_API_KEY",
                    "value": ""
                },
                {
                    "name": "PINECONE_ENVIRONMENT",
                    "value": ""
                },
                {
                    "name": "PINECONE_INDEX_NAME",
                    "value": ""
                },
                {
                    "name": "AWS_LOG_GROUP",
                    "value": ""
                },
                {
                    "name": "AWS_DEFAULT_REGION",
                    "value": ""
                }
            ],
            "ulimits": [
                {
                    "name": "nofile",
                    "softLimit": 65535,
                    "hardLimit": 65535
                }
            ]
        }
    ]
}